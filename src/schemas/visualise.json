{
  "$id": "https://hop.io/schemas/visualise.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Emulation-Aware Visualisation Contract",
  "allOf": [
    { "$ref": "https://hop.io/schemas/base-contract.json" }
  ],
  "properties": {
    "refcontract": { "const": "visualise" },
    "concept": { "type": "object", "default": {} },
    "experimentId": { "type": "string" },
    "scales": {
      "type": "object",
      "properties": {
        "cell": { "$ref": "#/definitions/emulationMapping" },
        "organ": { "$ref": "#/definitions/emulationMapping" },
        "bioregion": { "$ref": "#/definitions/emulationMapping" }
      },
      "additionalProperties": false
    },
    "computational": { "type": "object", "default": {} },
    "space": { "$ref": "https://hop.io/schemas/space.json" },
    "time": {
      "type": "object",
      "properties": {
        "createTimestamp": { "type": "number" },
        "lastTimestamp": { "type": "number" },
        "frequencyCount": { "type": "number" }
      },
      "required": ["createTimestamp", "lastTimestamp", "frequencyCount"]
    }
  },
  "definitions": {
    "emulationMapping": {
      "type": "object",
      "properties": {
        "component": { "type": "string", "description": "BentoBoxDS Vue Component" },
        "resonanceMapping": {
          "type": "object",
          "properties": {
            "input": { "type": "string", "default": "resonance_vector_primary" },
            "targetProperty": { "type": "string", "description": "e.g., 'turbidity', 'pulseRate', 'emission'" },
            "transformation": { "type": "string", "description": "JS math string or WASM hook" }
          },
          "required": ["targetProperty"],
          "additionalProperties": false
        }
      },
      "required": ["component", "resonanceMapping"],
      "additionalProperties": false
    }
  },
  "required": ["experimentId", "scales"],
  "additionalProperties": false
}
